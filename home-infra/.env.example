# Operator-local env para correr os scripts de bootstrap / destroy.
# Copia para home-infra/.env (gitignored) e preenche.
#
# Uso (a partir do root do repo):
#   set -a; . home-infra/.env; set +a
#   ./home-infra/scripts/bootstrap.sh
#   ./home-infra/my-services/iedora/scripts/bootstrap.sh
#
# Ou one-liner por comando:
#   env $(grep -v '^#' home-infra/.env | xargs) ./home-infra/scripts/bootstrap.sh

# BWS machine-account token (Bitwarden Secrets Manager).
# Onde obter: https://vault.bitwarden.com → Secrets Manager → Machine accounts
# Scope: read+write no project iedora.
BWS_ACCESS_TOKEN=0.<machine-account-id>.<token>

# Target homelab host (Beelink, etc) — formato ssh://user@ip
HOMELAB_HOST=ssh://root@192.168.50.53

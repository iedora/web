{
  "mcpServers": {
    "shadcn": {
      "command": "bunx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "postgres": {
      "command": "bunx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/menu"
      ]
    },
    "bun": {
      "command": "bunx",
      "args": ["-y", "mcp-bun@latest"]
    },
    "next-devtools": {
      "command": "bunx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "playwright": {
      "command": "bunx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
  }
}

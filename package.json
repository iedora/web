{
  "name": "iedora",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "products/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "bun run --workspaces typecheck",
    "lint": "bun run --workspaces lint",
    "test": "bun run --workspaces test",
    "ci:check": "actionlint -color .github/workflows/*.yml && (command -v shellcheck >/dev/null && shellcheck --shell=bash .github/scripts/*.sh || true)",
    "postinstall": "[ -n \"${CI:-}\" ] && exit 0; mkdir -p .git/hooks && cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo '✓ git hooks installed (actionlint + shellcheck)' || true"
  },
  "catalog": {
    "drizzle-orm": "^0.45.2",
    "drizzle-kit": "^0.31.10",
    "zod": "^4.4.3",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.7"
  }
}

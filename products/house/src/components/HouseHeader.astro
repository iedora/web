---
/**
 * Editorial header — minimal intro (just the wordmark) and the contact
 * "house" (shoji form) live in the same grid cell so the page below
 * never shifts when the form slides open. Host JS toggles `.open` on
 * the <header> when the wordmark is clicked.
 */
import { Wordmark } from "@iedora/design-system";
---

<header class="house" id="houseHeader">
  <div class="header-front">
    <h1
      class="wordmark-wrap"
      id="wordmark"
      role="button"
      tabindex="0"
      aria-label="Iedora — click to open contact"
    >
      <Wordmark variant="display" />
      <span class="hint" aria-hidden="true">Open the house</span>
    </h1>
    <p class="intro-line">A quiet house for digital craftsmanship.</p>
  </div>

  <!-- Contact house: slides open when the wordmark is clicked. -->
  <div class="contact-house" id="contactHouse" aria-hidden="true">
    <div class="ds-lintel">
      <span
        class="lintel-mark"
        id="lintelMark"
        role="button"
        tabindex="0"
        aria-label="Close contact"
      >
        <Wordmark variant="inline" />
      </span>
      <span class="ds-lintel__rule" aria-hidden="true"></span>
      <button type="button" class="lintel-close" id="closeContact">
        <svg class="arrow-icon" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M10 4 L6 8 L10 12" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="lbl">Back</span>
        <span class="kbd">Esc</span>
      </button>
    </div>

    <div class="ds-shoji" id="shoji">
      <div class="ds-shoji__inner">
        <form
          class="ds-pane-grid"
          id="contactForm"
          aria-label="Contact"
          autocomplete="on"
          novalidate
        >
          <label class="ds-pane">
            <span class="ds-pane__label">Name</span>
            <input
              class="ds-input"
              type="text"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              placeholder="—"
            />
          </label>
          <label class="ds-pane">
            <span class="ds-pane__label">From</span>
            <input
              class="ds-input"
              type="email"
              name="email"
              inputmode="email"
              autocomplete="email"
              spellcheck="false"
              required
              aria-required="true"
              placeholder="you@—"
            />
          </label>
          <label class="ds-pane ds-pane--full">
            <span class="ds-pane__label">Message</span>
            <textarea
              class="ds-textarea"
              name="message"
              rows="3"
              required
              aria-required="true"
              placeholder="Take your time. We read everything."
            ></textarea>
          </label>
          <div class="ds-pane ds-pane--full shoji-send">
            <button type="submit" class="ds-btn ds-btn--solid">
              <span>Send</span>
              <span class="ds-btn__arrow" aria-hidden="true">→</span>
            </button>
          </div>
        </form>
      </div>
      <div class="ds-shoji__receipt" role="status" aria-live="polite" aria-atomic="true">
        <div class="ds-shoji__receipt-inner">
          <div class="ds-shoji__seal" aria-hidden="true">i</div>
          <h4 class="ds-shoji__title">Received, gently.</h4>
          <p class="ds-shoji__body">Your message is inside the house. We will read it when the morning is quiet, and answer in kind.</p>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  /* Both children stack in the same grid cell so swapping intro ⇄ form
     keeps the total header height stable. The page below never shifts
     when the form slides open. The cell's height is the max of the
     intrinsic heights of `.header-front` and `.contact-house`; since
     the form is the taller of the two now, the form's content sets the
     intro's height. The wordmark anchors at the top of that area. */
  .house {
    position: relative;
    padding: 56px 0 64px;
    display: grid;
    grid-template-columns: 1fr;
  }
  .header-front {
    grid-row: 1;
    grid-column: 1;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    transition: opacity var(--d-3) var(--ease);
  }
  .house.open .header-front {
    opacity: 0;
    pointer-events: none;
  }
  .wordmark-wrap {
    margin: 0;
    display: inline-flex;
    align-items: end;
    cursor: pointer;
    user-select: none;
  }
  .wordmark-wrap .hint {
    align-self: end;
    margin-left: 18px;
    padding-bottom: 22px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-40);
    opacity: 0;
    transition: opacity var(--d-2) var(--ease);
    pointer-events: none;
  }
  .wordmark-wrap .hint::before {
    content: "";
    display: inline-block;
    width: 16px;
    height: 1px;
    background: var(--ink-40);
    transform: translateY(-3px);
    margin-right: 8px;
  }
  body.ds-loaded .wordmark-wrap:hover .hint { opacity: 1; }

  /* One sentence under the wordmark — fades in shortly after the
     letter-by-letter reveal lands. */
  .intro-line {
    margin: 22px 0 0;
    max-width: 38ch;
    font-family: var(--serif);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-70);
    text-wrap: pretty;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--d-5) 0.85s var(--ease), transform var(--d-5) 0.85s var(--ease);
  }
  body.ds-loaded .intro-line { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .intro-line { transition: none; }
  }

  /* Contact pane — same cell as the front, fades in on .open */
  .contact-house {
    position: relative;
    grid-row: 1;
    grid-column: 1;
    align-self: stretch;
    width: 100%;
    opacity: 0;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: opacity var(--d-3) var(--ease);
  }
  .house.open .contact-house {
    opacity: 1;
    pointer-events: auto;
  }
  .lintel-mark {
    cursor: pointer;
    user-select: none;
    display: inline-flex;
    align-items: baseline;
  }
  .lintel-close {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px 7px 10px;
    background: var(--paper);
    border: 1.25px solid var(--ink);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--d-2) var(--ease), color var(--d-2) var(--ease), transform var(--d-2) var(--ease);
  }
  .lintel-close:hover {
    background: var(--ink);
    color: var(--paper);
    transform: translateX(-3px);
  }
  .lintel-close .arrow-icon {
    width: 14px;
    height: 14px;
    display: block;
    transition: transform var(--d-2) var(--ease);
  }
  .lintel-close:hover .arrow-icon { transform: translateX(-3px); }
  .lintel-close .kbd {
    font-size: 9px;
    padding: 3px 6px;
    border: 1px solid currentColor;
    border-radius: 3px;
    opacity: 0.5;
    letter-spacing: 0.1em;
  }
  .lintel-close:hover .kbd { opacity: 0.85; }

  /* Send button cell — right-aligned, no borders on the parent pane */
  .shoji-send {
    display: flex;
    justify-content: flex-end;
    padding-top: 14px;
    padding-bottom: 0;
    border-bottom: 0;
    border-right: 0;
  }

  @media (max-width: 1080px) {
    .house { padding: 40px 0 48px; }
  }
  @media (max-width: 680px) {
    .wordmark-wrap .hint { display: none; }
    .lintel-close .lbl { display: none; }
    .lintel-close { padding: 6px 10px; }
    .house { padding: 24px 0 32px; }
  }
  @media (max-width: 420px) {
    .lintel-close .kbd { display: none; }
  }
</style>

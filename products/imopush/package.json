{
  "name": "@iedora/product-imopush",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "imopush product \u2014 TBD. Scaffold only; slices + drizzle schema land in follow-up commits. Uses RELATIVE imports internally (no @/ path mapping) so apps/web's tsconfig stays clean as products land.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --bun drizzle-kit studio"
  },
  "dependencies": {
    "@iedora/auth": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/design-system": "workspace:*",
    "@iedora/observability": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.9",
    "server-only": "^0.0.1",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/react": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}

# Genkan product (genkan.iedora.com) — infra entry point.
#
# Layout: one Tofu root (tofu/ — Cloudflare tunnel + DNS), one Kamal config
# (kamal/) for the app, one Dockerfile, and a Bitwarden Secrets Manager hookup
# (shared with menu) via `bin/with-secrets`.
#
# Genkan has NO postgres / backups / R2 of its own. The auth.* schema lives in
# the shared `infra-postgres` accessory (owned by /infra/) — see kamal/config/deploy.yml.
#
# `just` (no args) lists every recipe.

set dotenv-load := true

# Kamal is a Ruby gem. On macOS with brew-Ruby the binary lands outside PATH;
# probe the usual places. Same dance as products/menu/infra/justfile.
kamal-bin := `
  for d in /opt/homebrew/lib/ruby/gems/*/bin /usr/local/lib/ruby/gems/*/bin "$HOME"/.gem/ruby/*/bin "$HOME"/.rbenv/versions/*/bin; do
    [ -d "$d" ] && { printf '%s:' "$d"; exit 0; }
  done
`

tofu := "bin/with-secrets tofu -chdir=tofu"

_default:
    @just --list --unsorted

# Build + push + deploy genkan — idempotent. Tofu reconciles CF resources;
# Kamal deploys the app. They meet at kamal/.kamal/secrets (which reads
# `tofu output`).
#
# Steps:
#   1. bun install --frozen-lockfile  — fail fast on stale workspace lock
#   2. tofu apply                     — reconcile tunnel + DNS
#   3. kamal accessory boot all       — ensure cloudflared exists EVEN when
#                                       step 4 picks `kamal deploy` (which
#                                       silently skips accessory boot). This
#                                       is the fix for the 2nd-product 530
#                                       bug — see docs/deploy.md.
#   4. kamal setup OR deploy          — full setup on first run; deploy after
#   5. curl /up                       — smoke-test the public endpoint
deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    (cd ../../.. && bun install --frozen-lockfile)
    {{tofu}} init -upgrade -input=false >/dev/null
    {{tofu}} apply -auto-approve
    bin/with-secrets bash -c \
      'cd kamal && PATH="{{kamal-bin}}$PATH" exec kamal accessory boot all'
    if ssh -o ConnectTimeout=5 -o BatchMode=yes "root@${ONPREM_HOST}" \
         'docker ps --quiet --filter name=kamal-proxy' 2>/dev/null | grep -q .; then
      KAMAL_CMD=deploy
    else
      KAMAL_CMD=setup
    fi
    KAMAL_CMD="$KAMAL_CMD" bin/with-secrets bash -c \
      'cd kamal && PATH="{{kamal-bin}}$PATH" exec kamal "$KAMAL_CMD"'
    echo "[deploy] smoke-checking https://${PUBLIC_HOSTNAME}/up …"
    for i in 1 2 3 4 5 6; do
      CODE=$(curl -s -o /dev/null -w '%{http_code}' "https://${PUBLIC_HOSTNAME}/up" || echo 000)
      if [ "$CODE" = "200" ]; then echo "[deploy] ✓ /up returned 200"; exit 0; fi
      echo "[deploy] /up returned ${CODE}; retry $i/6 in 5s"
      sleep 5
    done
    echo "[deploy] ✗ /up never returned 200 after 30s. Check 'just genkan::logs' and 'kamal accessory logs cloudflared'." >&2
    exit 1

# Tear down genkan's Cloudflare resources. Stops the local cloudflared
# accessory + flushes Cloudflare's connection registry first — both make
# `tofu destroy` race-free against Cloudflare's ~30-60s connection-slot TTL.
destroy:
    #!/usr/bin/env bash
    set -euo pipefail
    bin/with-secrets bash -c \
      'cd kamal && PATH="{{kamal-bin}}$PATH" kamal accessory stop cloudflared 2>/dev/null || true'
    TUNNEL_ID=$({{tofu}} output -raw tunnel_id 2>/dev/null || true)
    if [ -n "$TUNNEL_ID" ]; then
      bin/with-secrets bash -c '
        curl -s -X DELETE \
          -H "Authorization: Bearer $INFRA_CLOUDFLARE_API_TOKEN" \
          "https://api.cloudflare.com/client/v4/accounts/$CLOUDFLARE_ACCOUNT_ID/cfd_tunnel/'"$TUNNEL_ID"'/connections" >/dev/null
      '
    fi
    {{tofu}} destroy -auto-approve

# Tail app logs.
logs:
    bin/with-secrets bash -c 'cd kamal && PATH="{{kamal-bin}}$PATH" exec kamal app logs -f'

# Bash inside the app container.
console:
    bin/with-secrets bash -c 'cd kamal && PATH="{{kamal-bin}}$PATH" exec kamal app exec --interactive --reuse bash'

# Roll back to the previous version.
rollback:
    bin/with-secrets bash -c 'cd kamal && PATH="{{kamal-bin}}$PATH" exec kamal rollback'

# Rotate one shared BWS secret. Usage: just rotate-secret GENKAN_AUTH_SECRET.
# WARNING: GENKAN_AUTH_SECRET rotation invalidates every genkan session;
# INFRA_POSTGRES_PASSWORD rotation needs `kamal accessory reboot postgres` after
# and impacts BOTH products (shared accessory).
rotate-secret key:
    #!/usr/bin/env bash
    set -euo pipefail
    SECRET_ID=$(bws secret list "$BWS_PROJECT_ID" -o json | jq -r '.[] | select(.key=="{{key}}") | .id')
    [ -n "$SECRET_ID" ] || { echo "No BWS secret named {{key}} in project"; exit 1; }
    printf "New value for {{key}} (no echo): "
    stty -echo; read -r NEW; stty echo; printf "\n"
    [ -n "$NEW" ] || { echo "Empty value, aborting"; exit 1; }
    bws secret edit "$SECRET_ID" --value "$NEW" -o none
    echo "✓ {{key}} rotated in BWS"
    echo "→ redeploy menu AND genkan to pick up the new value"

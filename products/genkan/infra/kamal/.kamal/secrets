# Kamal evaluates this file with shell semantics. KEY=value_or_$(expr).
# Working dir is infra/kamal/. No actual secret values — only references.
# Safe to commit.
#
# Sources:
#   Bitwarden Secrets Manager (shared project with menu) → app passwords
#   Tofu state (encrypted)                                → tunnel token
#   gh CLI (fallback only)                                → GHCR password if no INFRA_GHCR_TOKEN
#
# BWS_PROJECT_ID and BWS_ACCESS_TOKEN come from infra/.env via justfile's
# `set dotenv-load`.

# Bulk-fetch every secret in the (shared) BWS project once.
SECRETS=$(kamal secrets fetch --adapter bitwarden-sm --from $BWS_PROJECT_ID all)

# Tofu state is encrypted (see infra/tofu/versions.tf). TF_VAR_state_passphrase
# is injected by `bin/with-secrets` (justfile wraps `kamal` in it), so every
# $(tofu output …) subshell inherits it.
TUNNEL_TOKEN=$(tofu -chdir=../tofu output -raw tunnel_token 2>/dev/null)

# GHCR — dedicated `write:packages` PAT, stored in BWS as INFRA_GHCR_TOKEN.
# CI uses the same BWS value via bws CLI. DO NOT use ${VAR:-default} —
# Kamal's secrets-file parser mangles it (see menu's secrets file comment).
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract INFRA_GHCR_TOKEN $SECRETS)

# Genkan signs its own JWTs / cookies. Menu validates them via OIDC, NOT
# by sharing the secret — the OAuth handshake exchanges a code for an
# id_token that menu verifies against genkan's published JWKS. So genkan
# has its own GENKAN_AUTH_SECRET in BWS, distinct from menu's.
BETTER_AUTH_SECRET=$(kamal secrets extract GENKAN_AUTH_SECRET $SECRETS)

# Genkan reaches into the shared `infra-postgres` accessory (owned by
# the top-level infra/ workspace) on its OWN database — `genkan` (created
# lazily by migrate.mjs on first boot). INFRA_POSTGRES_PASSWORD is the
# superuser password set by the infra Postgres accessory.
POSTGRES_PASSWORD=$(kamal secrets extract INFRA_POSTGRES_PASSWORD $SECRETS)
DATABASE_URL=postgres://postgres:$POSTGRES_PASSWORD@infra-postgres:5432/genkan

# Pre-registered first-party OAuth clients. One line per client:
#
#   client_id|client_secret|redirect_uri_1,redirect_uri_2
#
# The values come from BWS as separate secrets (`MENU_OAUTH_CLIENT_ID`,
# `MENU_OAUTH_CLIENT_SECRET`, …) so rotation is per-client. New first-party
# product = new BWS secret pair + one line below. Third-party clients
# register dynamically via /admin/applications and live in oauth_client.
MENU_CLIENT_ID=$(kamal secrets extract MENU_OAUTH_CLIENT_ID $SECRETS)
MENU_CLIENT_SECRET=$(kamal secrets extract MENU_OAUTH_CLIENT_SECRET $SECRETS)
TRUSTED_CLIENTS="$MENU_CLIENT_ID|$MENU_CLIENT_SECRET|https://menu.iedora.com/api/auth/oauth2/callback/genkan"

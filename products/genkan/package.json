{
  "name": "genkan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/check-migrations.ts && next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --bun drizzle-kit studio",
    "auth:generate": "better-auth generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.11",
    "@iedora/design-system": "workspace:*",
    "@iedora/identity": "workspace:*",
    "better-auth": "1.6.11",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@electric-sql/pglite": "^0.4.5",
    "@iedora/auth-testkit": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "ignoreScripts": [
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "unrs-resolver"
  ]
}

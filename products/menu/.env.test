# Test fixtures. Single source for the env every E2E surface needs —
# Playwright workers, the production-build Next.js webServer, the
# better-auth instance, and every CI step. Same shape as dev `.env`
# (TF-emitted) so the schema stays homogeneous; values are test fakes.
#
# Load contract:
#   - Locally: `bun --env-file=.env.test ...` (baked into the
#     test:e2e + test:e2e:* scripts in package.json).
#   - In CI: the menu workflow runs the same scripts; --env-file
#     pulls this file from the workspace.

NODE_ENV=production
DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/menu_test
CORE_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/core_test
IEDORA_CORE_SECRET=test-iedora-auth-secret-do-not-use-in-prod-32chars
IEDORA_CORE_BASE_URL=http://localhost:3000
IEDORA_CORE_TRUSTED_ORIGINS=http://localhost:3000
IEDORA_CORE_COOKIE_DOMAIN=localhost
NEXT_PUBLIC_CORE_URL=http://localhost:3000/core
MENU_PUBLIC_URL=http://localhost:3000
DISABLE_RATE_LIMIT=true

# S3 mock — adobe/s3mock (used in both CI and dev since LocalStack `:latest`
# requires a paid licence as of 2026). Override S3_ENDPOINT via shell or
# .env.test.local if pointing at a different mock.
S3_ENDPOINT=http://localhost:9090
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=menu-test

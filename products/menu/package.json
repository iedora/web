{
  "name": "@iedora/product-menu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Menu product — UI slices + thin server actions over the Go menu service (services/cmd/menu). The Next.js routes live in apps/web/src/app/; this package exposes its slice + shared barrels via explicit subpath exports so apps/web routes can import them by name (no tsconfig fallback).",
  "exports": {
    ".": "./src/index.ts",
    "./i18n/messages/*.json": "./src/i18n/messages/*.json",
    "./features/auth": "./src/features/auth/index.ts",
    "./features/auth/actions": "./src/features/auth/actions.ts",
    "./features/dashboard-home": "./src/features/dashboard-home/index.ts",
    "./features/dashboard-home/ui/analytics-cards": "./src/features/dashboard-home/ui/analytics-cards.tsx",
    "./features/dashboard-home/ui/logout-button": "./src/features/dashboard-home/ui/logout-button.tsx",
    "./features/dashboard-home/ui/user-locale-switcher": "./src/features/dashboard-home/ui/user-locale-switcher.tsx",
    "./features/i18n": "./src/features/i18n/index.ts",
    "./features/menu-builder": "./src/features/menu-builder/index.ts",
    "./features/menu-builder/ui/builder": "./src/features/menu-builder/ui/builder.tsx",
    "./features/menu-builder/ui/create-menu-dialog": "./src/features/menu-builder/ui/create-menu-dialog.tsx",
    "./features/menu-builder/ui/seed-sample-button": "./src/features/menu-builder/ui/seed-sample-button.tsx",
    "./features/menu-onboarding": "./src/features/menu-onboarding/index.ts",
    "./features/menu-publishing": "./src/features/menu-publishing/index.ts",
    "./features/menu-publishing/rsc/menu-renderer": "./src/features/menu-publishing/rsc/menu-renderer.tsx",
    "./features/menu-publishing/rsc/public-menu-view": "./src/features/menu-publishing/rsc/public-menu-view.tsx",
    "./features/menu-publishing/rsc/public-menu-view-ui": "./src/features/menu-publishing/rsc/public-menu-view-ui.tsx",
    "./features/menu-publishing/rsc/theme": "./src/features/menu-publishing/rsc/theme.ts",
    "./features/menu-publishing/rsc/types": "./src/features/menu-publishing/rsc/types.ts",
    "./features/metrics": "./src/features/metrics/index.ts",
    "./features/plans": "./src/features/plans/index.ts",
    "./features/qr-codes": "./src/features/qr-codes/index.ts",
    "./features/qr-codes/stats": "./src/features/qr-codes/stats.ts",
    "./features/qr-codes/ui/qr-codes-admin": "./src/features/qr-codes/ui/qr-codes-admin.tsx",
    "./features/restaurant-identity": "./src/features/restaurant-identity/index.ts",
    "./features/restaurant-identity/ui/restaurant-qr-shelf": "./src/features/restaurant-identity/ui/restaurant-qr-shelf.tsx",
    "./features/restaurant-identity/ui/theme-editor": "./src/features/restaurant-identity/ui/theme-editor.tsx",
    "./features/restaurant-slug": "./src/features/restaurant-slug/index.ts",
    "./shared/api": "./src/shared/api.ts",
    "./shared/auth-urls": "./src/shared/auth-urls.ts",
    "./shared/ui/active-sidebar-links": "./src/shared/ui/active-sidebar-links.tsx",
    "./shared/ui/dashboard-page": "./src/shared/ui/dashboard-page.tsx",
    "./shared/ui/editorial-list": "./src/shared/ui/editorial-list/index.ts",
    "./shared/url": "./src/shared/url.ts"
  },
  "scripts": {
    "typecheck": "tsgo --build && tsgo -p tsconfig.tests.json --noEmit",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iedora/api-client": "workspace:*",
    "@iedora/brand": "workspace:*",
    "@iedora/design-system": "workspace:*",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "next": "^16.2.6",
    "next-intl": "^4.9.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/qrcode": "^1.5.6",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "catalog:",
    "next": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}

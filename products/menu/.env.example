# Menu dev template — copy to `.env.local`, fill in.
# `.env.local` is gitignored; `.env.example` is the tracked source of truth.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metamenu

# Better Auth — generate with: openssl rand -base64 32. Menu's local session
# secret only — NOT shared with Genkan (menu is a pure OAuth client now).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Genkan OAuth client credentials. Issued by Genkan when menu was registered
# as an OIDC client. The discovery doc is fetched from
# ${GENKAN_ISSUER_URL}/.well-known/openid-configuration at request time.
GENKAN_OAUTH_CLIENT_ID=menu-dev
GENKAN_OAUTH_CLIENT_SECRET=dev-secret-change-me
GENKAN_ISSUER_URL=http://localhost:3001

# Cache / Queue
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible: LocalStack local, R2/S3 in prod)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=metamenu

# OpenTelemetry / observability ----------------------------------------------
# OTLP HTTP endpoint that the @iedora/observability SDK ships spans to.
# Production points at the shared `infra-openobserve` container on the
# `kamal` Docker network. Append `/api/<org>` — OpenObserve serves OTLP
# under that org-scoped path. Leave blank in local dev unless you've
# started a collector — the SDK degrades to a "logs once at boot, never
# exports" mode when unset.
# Production: http://infra-openobserve:5080/api/default
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTLP ingest auth — `Authorization=Basic%20<base64(email:password)>`.
# The Basic Auth credentials are OpenObserve's root user (or a dedicated
# ingest user — see docs/observability.md). One-time bootstrap stored in
# BWS as INFRA_OPENOBSERVE_INGEST_HEADER. URL-encoded form: spaces → %20.
OTEL_EXPORTER_OTLP_HEADERS=

# Git SHA — CI passes this at build time via --build-arg GIT_SHA=…
# Becomes the `service.version` resource attribute. Local dev: leave blank.
GIT_SHA=

# Per-host name (matches the iedora fleet manifest, see issue #8). Becomes
# the `host.name` resource attribute so cross-product traces can filter by
# host. Local dev: leave blank.
HOST_NAME=

# Multi-instance prod only — generate with: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
# DEPLOYMENT_VERSION=

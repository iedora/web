# Menu product (menu.iedora.com) — infra entry point.
#
# Menu's APPLICATION deploy lives at the repo-root `infra/` workspace
# now (Tofu-managed `docker_container.menu_web` on the Hetzner VPS):
#
#     just infra::deploy            # boots / updates the menu container
#
# This product-local `infra/` only owns menu's R2 assets bucket + the
# `assets.iedora.com` custom-domain DNS — things that don't belong in
# the shared VPS root. The Dockerfile in this directory is consumed by
# the `menu.yml` CI workflow (image build + push to GHCR).
#
# Sibling products live at ../../<name>/infra/ (e.g. ../../house/infra/).
# Each product is self-contained — its own tofu state, its own justfile,
# its own .env.
#
# `just` (no args) lists every recipe.

set dotenv-load := true

tofu := "bin/with-secrets tofu -chdir=tofu"

# Default: list recipes.
_default:
    @just --list --unsorted

# Tofu apply for the R2 assets bucket + assets.iedora.com custom domain.
# Writes the resulting R2 credentials + public URL into BWS so the app
# container (booted by the repo-root `infra` workspace) reads the fresh
# values on its next roll. Rare — only needed when the bucket itself or
# its CORS / custom-domain configuration changes.
[doc("apply R2 + assets-DNS Tofu, write outputs to BWS")]
infra:
    #!/usr/bin/env bash
    set -euo pipefail
    {{tofu}} init -upgrade -input=false >/dev/null
    {{tofu}} apply -auto-approve
    echo "[infra] writing tofu outputs to BWS …"
    for PAIR in "assets_endpoint:INFRA_MENU_ASSETS_ENDPOINT" \
                "assets_bucket_name:INFRA_MENU_ASSETS_BUCKET" \
                "assets_r2_access_key_id:INFRA_MENU_ASSETS_ACCESS_KEY" \
                "assets_r2_secret_access_key:INFRA_MENU_ASSETS_SECRET_KEY" \
                "assets_public_url:INFRA_MENU_ASSETS_PUBLIC_URL"; do
      OUTPUT=${PAIR%%:*}
      KEY=${PAIR##*:}
      VAL=$({{tofu}} output -raw "$OUTPUT")
      SECRET_ID=$(bws secret list "$BWS_PROJECT_ID" -o json | jq -r --arg k "$KEY" '.[] | select(.key==$k) | .id')
      if [ -n "$SECRET_ID" ]; then
        bws secret edit "$SECRET_ID" --value "$VAL" -o none >/dev/null
      else
        bws secret create -o none -- "$KEY" "$VAL" "$BWS_PROJECT_ID" >/dev/null
      fi
    done
    echo "[infra] ✓ done. The repo-root infra workspace will pick up the new R2 creds on the next 'just infra::deploy'."

# Tear down menu's Cloudflare-owned resources (R2 bucket + custom domain
# + scoped token). Does NOT touch the VPS or the menu container — those
# live in the repo-root infra workspace.
[doc("destroy menu's R2 bucket + assets DNS (Cloudflare side only)")]
destroy:
    {{tofu}} destroy -auto-approve

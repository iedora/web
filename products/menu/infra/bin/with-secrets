#!/bin/sh
# Wrap a command with secrets fetched from Bitwarden Secrets Manager,
# then exec the command in-place. The wrapped process inherits all BWS
# secrets as env vars + a handful of TF_VAR_* aliases Tofu expects.
#
# Scope: this wrapper sets only the variables menu's product-local Tofu
# root needs (R2 assets bucket + assets.iedora.com custom domain). The
# app's deploy uses the repo-root `infra/` workspace and its own wrapper.
#
# Why we DON'T use `bws run`: it spawns a child process that resets cwd
# and swallows the first line of stdout (observed with bws 2.0.0). We
# just `bws secret list -o env` + eval into the current shell instead,
# then exec — same end state, no subprocess oddities.
#
# Requires (loaded from infra/.env via justfile's set dotenv-load):
#   BWS_ACCESS_TOKEN    machine-account token
#   BWS_PROJECT_ID      project UUID
#   CLOUDFLARE_ACCOUNT_ID, PUBLIC_HOSTNAME  (Tofu inputs, non-secret so
#                       they live in .env, not BWS)
#
# Usage:
#   infra/bin/with-secrets <cmd> [args...]
#
# Example:
#   infra/bin/with-secrets tofu -chdir=tofu apply -auto-approve
set -eu

# When invoked directly (not from just), source infra/.env ourselves so
# the wrapper is self-contained. justfile already exports these via
# `set dotenv-load`, so this is a no-op there.
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ENV_FILE="$SCRIPT_DIR/../.env"
if [ -f "$ENV_FILE" ] && [ -z "${BWS_ACCESS_TOKEN:-}" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

: "${BWS_ACCESS_TOKEN:?infra/.env missing BWS_ACCESS_TOKEN}"
: "${BWS_PROJECT_ID:?infra/.env missing BWS_PROJECT_ID}"

# Pull every secret in the project as `KEY="value"` lines and source them
# into the current shell. `set -a` auto-exports every variable assigned in
# the eval'd block, so the wrapped command (after `exec`) sees them.
set -a
eval "$(bws secret list "$BWS_PROJECT_ID" -o env)"
set +a

# TF_VAR_* aliases — Tofu reads inputs from these specific names. The zone
# is no longer passed in; Tofu looks it up live via `data.cloudflare_zone`
# given var.public_hostname (see infra/tofu/menu.tf).
export TF_VAR_account_id="${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID missing}"
export TF_VAR_cloudflare_api_token="${INFRA_CLOUDFLARE_API_TOKEN:?INFRA_CLOUDFLARE_API_TOKEN missing in BWS}"
export TF_VAR_state_passphrase="${INFRA_STATE_PASSPHRASE:?INFRA_STATE_PASSPHRASE missing in BWS}"
export TF_VAR_public_hostname="${PUBLIC_HOSTNAME:?PUBLIC_HOSTNAME missing}"

exec "$@"

# Kamal destinations split secrets into:
#   .kamal/secrets-common      — values shared across destinations (this file's shape)
#   .kamal/secrets.onprem      — values that only apply to -d onprem
#   .kamal/secrets.hetzner     — values that only apply to -d hetzner
#
# Copy this file to `.kamal/secrets-common` (gitignored) and fill in.
# Per-destination files exist as empty placeholders; override values there
# only when they must differ between destinations.
#
# Syntax is bash — `KEY=$(cmd)` or `KEY=value`. The file is sourced.
#
# Generate fresh secrets:
#   BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#   POSTGRES_PASSWORD=$(openssl rand -base64 24)
#
# Production-grade alternative (2026 best practice): replace plain values
# with `kamal secrets fetch` from 1Password / AWS Secrets Manager / etc.
# See: kamal-deploy.org/docs/commands/secrets/

# Registry (GHCR) — gh CLI logged in resolves the token on the fly.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# ── App ──────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=

# Postgres accessory — the password MUST match the one embedded in DATABASE_URL.
POSTGRES_PASSWORD=

# Connection strings — use the Docker network names (kamal-* network).
# Replace CHANGEME with the POSTGRES_PASSWORD value above.
DATABASE_URL=postgres://postgres:CHANGEME@meta-menu-postgres:5432/metamenu
REDIS_URL=redis://meta-menu-redis:6379

# ── R2 / S3 access keys ──────────────────────────────────────────────────────
# R2:    `make cf-r2-token` prints the one-click dashboard steps.
# AWS:   create an IAM user with s3:Put/Get/Delete on the bucket.
# S3_ENDPOINT/S3_REGION/S3_BUCKET come from .envrc (set by cf-sync.sh).
S3_ACCESS_KEY=
S3_SECRET_KEY=

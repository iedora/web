# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies — each product has its own node_modules (no workspaces)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Vitest
.vitest-cache/

# next.js
.next/
/out/

# Astro build output — products/house/dist is regenerated on every deploy
# (Tofu reads it during apply). Don't track build artifacts.
products/house/dist/

# Dev-loop artifacts. The shared dev infra lives at infra/dev/ (mirror
# of prod's infra/tofu/). Per-product .env.local files are emitted by
# the dev TF seed.
#   - .zitadel-bootstrap/  PATs minted by FirstInstance on first compose up
#   - infra/dev/tofu/.terraform* / terraform.tfstate*  throwaway local state
#   - products/*/.env.local  generated by infra/dev/tofu/ seed
infra/dev/.zitadel-bootstrap/
infra/dev/tofu/.terraform/
infra/dev/tofu/.terraform.lock.hcl
infra/dev/tofu/terraform.tfstate*
products/menu/.env.local

# Prod tofu — state lives in R2 via the `s3` backend, never in git
# (Rule 2, docs/deploy.md § Environment guardrails). The `.terraform/`
# provider cache is regenerated by `tofu init`. The `.terraform.lock.hcl`
# stays tracked (pins provider versions for reproducibility).
infra/tofu/.terraform/
infra/tofu/terraform.tfstate
infra/tofu/terraform.tfstate.backup
infra/tofu/terraform.tfstate.*.backup
products/house/infra/tofu/.terraform/
products/house/infra/tofu/terraform.tfstate
products/house/infra/tofu/terraform.tfstate.backup
products/house/infra/tofu/terraform.tfstate.*.backup
# products/menu/.env IS TRACKED — statics + placeholders for the dynamic
# keys, regenerated by `bun run dev` (infra/modules/menu_env). Commit
# changes when the env schema evolves; runtime overrides live in .env.local.

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production

# Opt-in: products/menu/.env IS committed — TF-emitted by infra/modules/menu_env
# (localhost-DNS variant). Statics + Zod-valid placeholders for the dynamic
# keys; real values land in .env.local (gitignored). This negation has to come
# AFTER the global `.env` rule above.
!products/menu/.env
.env.*.local
!.env.test
# Per-product infra .env: gitignored, operator-owned (holds BWS_ACCESS_TOKEN).
products/*/infra/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Jazzer fuzz harness build output (transient — produced by `bun run fuzz:build`).
.fuzz-build/

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
playwright/.auth/

# Claude Code — local user settings (skills are shared)
.claude/settings.local.json
.claude/

# Infra — tofu state, never in git
**/.terraform/
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/terraform.tfstate.d/
**/terraform.tfvars
# .terraform.lock.hcl SHOULD be committed — pins provider versions

# Go build artefacts from `go build ./cmd/...` invoked at infra/. The
# binaries are named after the cmd folder and land in infra/. We always
# run via `go run` through the bin/ shims, never from a pre-built binary.
# (`infra/dev` is omitted on purpose — it's a tracked directory.)
/infra/iedora
/infra/with-secrets
/infra/zitadel-grant
/infra/zitadel-apply
/infra/bws-upsert
/infra/menu-db-migrations
/infra/openobserve-dashboards
/infra/state-bucket-bootstrap

# Backup artefacts — `make restore` and ad-hoc pg_dump leave these in cwd.
# Database dumps are the most sensitive payload in the repo; never commit one
# even if it lands gpg-encrypted (the file shape leaks volume + schedule).
*.dump
*.dump.gpg
*.sql.gz
*.bak
.playwright-mcp/

# Ad-hoc screenshots from Playwright/dev sessions land in the repo root.
# Tests put intentional screenshots under tests/e2e/screenshots/ instead.
/*.png
products/menu/tests/e2e/.testkit.json

# Local reference checkouts (not part of the repo)
services-references/

# See https://git-scm.com/docs/gitignore for more about ignoring files.

# dependencies — bun workspaces resolve from the repo root, so the only
# node_modules anywhere should be at the root (plus a symlink-style
# layout in each workspace).
node_modules/

# testing
/coverage
.vitest-cache/

# next.js
.next/
/out/

# production
/build

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
playwright/.auth/

# Local reference checkouts (not part of the repo)
.playwright-mcp/
services-references/

# Ad-hoc screenshots from Playwright / dev sessions land in the repo
# root. Intentional fixture screenshots live under tests/e2e/screenshots/.
/*.png

# Backup artefacts — `bin/iedora backup` and ad-hoc pg_dump leave these
# in cwd. Database dumps are the most sensitive payload anywhere in the
# repo; never commit one even gpg-encrypted (the shape leaks volume +
# schedule).
*.dump
*.dump.gpg
*.sql.gz
*.bak

# Go build artefacts from `go build ./...` invoked at the repo root.
# The binaries land in the cwd named after their `cmd/<name>/`
# directory. We always run via `go run` (through bin/ shims for the
# live binaries), never from a pre-built binary, so any compiled
# binary at the repo root is stray.
/bws-sync
/bws-upsert
/iedora
/infra-pg-backup
# bin/dev-stack — bash script, no binary
/menu-db-migrations
/openobserve-dashboards
/state-bucket-bootstrap

# OS / editor
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# env files. `.env` is gitignored — the dev orchestrator
# (`bin/dev-stack`) composes it on every run. `.env.test` is tracked
# — single source for the E2E env every CI step + the Playwright
# webServer reads.
.env
.env.local
.env.production
.env.*.local
!.env.test

# Kamal secrets — populated locally, never committed.
# Covers `.kamal/secrets`, `.kamal/secrets-common`, `.kamal/secrets.<destination>`.
/.kamal/secrets*

# homelab-core-infra .env (provider-side secrets for shared infra).
/homelab-core-infra/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Tofu state — never in git. State + lock live in Cloudflare R2 via the
# `s3` backend (docs/deploy.md § Environment guardrails Rule 2).
# `.terraform/` is the provider cache, regenerated by `tofu init`.
# `.terraform.lock.hcl` IS committed (pins provider versions).
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/terraform.tfstate.d/
**/terraform.tfvars

# Claude Code — local user settings, scheduled-task locks, etc. Skills
# under `.claude/skills/` are shared and stay tracked.
.claude/*
!.claude/skills/

# Playwright testkit handoff
products/menu/tests/e2e/.testkit.json
dist/

# dev-stack sentinel: source fingerprint used to skip web image
# rebuilds when nothing changed (bin/dev-stack::web_needs_rebuild).
dev/.web-build-hash

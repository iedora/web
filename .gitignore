# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies — each product has its own node_modules (no workspaces)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Vitest
.vitest-cache/

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.*.local
!.env.example
!.env.test
# Per-product infra .env (gitignored); the example files ARE tracked.
products/*/infra/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Jazzer fuzz harness build output (transient — produced by `bun run fuzz:build`).
.fuzz-build/

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
playwright/.auth/

# Claude Code — local user settings (skills are shared)
.claude/settings.local.json
.claude/

# Infra — tofu state, never in git
**/.terraform/
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/terraform.tfstate.d/
**/terraform.tfvars
# .terraform.lock.hcl SHOULD be committed — pins provider versions

# Backup artefacts — `make restore` and ad-hoc pg_dump leave these in cwd.
# Database dumps are the most sensitive payload in the repo; never commit one
# even if it lands gpg-encrypted (the file shape leaks volume + schedule).
*.dump
*.dump.gpg
*.sql.gz
*.bak
.playwright-mcp/

# Ad-hoc screenshots from Playwright/dev sessions land in the repo root.
# Tests put intentional screenshots under tests/e2e/screenshots/ instead.
/*.png
products/menu/tests/e2e/.testkit.json

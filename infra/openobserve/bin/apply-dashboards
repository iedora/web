#!/usr/bin/env bash
# apply-dashboards — push every JSON in infra/openobserve/dashboards/ to OpenObserve.
#
# Idempotent. For each local file:
#   1. List existing dashboards in the target folder.
#   2. If one matches by `title`, GET its current state to extract the `hash`,
#      then PUT with that hash (optimistic concurrency).
#   3. Otherwise, POST as a new dashboard.
#
# Why bash and not Terraform: there is no first-party OpenObserve TF provider
# in 2026; the community providers don't speak v5 schema. A 60-line bash
# script with curl + jq beats waiting on a third-party module.
#
# Usage (from the repo root):
#   bin/with-secrets infra/openobserve/bin/apply-dashboards
#
# Env (populated by bin/with-secrets from BWS):
#   INFRA_OPENOBSERVE_ROOT_USER_EMAIL          — login email
#   AUTOGEN_INFRA_OPENOBSERVE_ROOT_USER_PASSWORD — login password (TF-minted)
#
# Override the target URL/org for local dev:
#   OO_BASE_URL=http://localhost:5080 OO_ORG=default \
#     bin/with-secrets infra/openobserve/bin/apply-dashboards

set -euo pipefail

OO_BASE_URL="${OO_BASE_URL:-https://obs.iedora.com}"
OO_ORG="${OO_ORG:-default}"
OO_FOLDER="${OO_FOLDER:-default}"

EMAIL="${INFRA_OPENOBSERVE_ROOT_USER_EMAIL:?set INFRA_OPENOBSERVE_ROOT_USER_EMAIL (via bin/with-secrets)}"
PASSWORD="${AUTOGEN_INFRA_OPENOBSERVE_ROOT_USER_PASSWORD:?set AUTOGEN_INFRA_OPENOBSERVE_ROOT_USER_PASSWORD (via bin/with-secrets)}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DASHBOARDS_DIR="${SCRIPT_DIR}/../dashboards"

if [[ ! -d "$DASHBOARDS_DIR" ]]; then
  echo "✗ dashboards dir not found: $DASHBOARDS_DIR" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "✗ jq is required (brew install jq)" >&2
  exit 1
fi

# Cache the existing-dashboards listing once per run.
LIST_RESPONSE=$(curl -sf -u "$EMAIL:$PASSWORD" \
  "$OO_BASE_URL/api/$OO_ORG/dashboards?folder=$OO_FOLDER" \
  -H 'Accept: application/json')

echo "→ Applying dashboards to $OO_BASE_URL (org=$OO_ORG folder=$OO_FOLDER)"

shopt -s nullglob
for json_file in "$DASHBOARDS_DIR"/*.json; do
  title=$(jq -r '.title' "$json_file")
  echo "  • $(basename "$json_file") — title=\"$title\""

  # The list payload nests dashboards under different keys across versions.
  # Try each shape we've seen: top-level array, .list[], .dashboards[].
  #
  # CRITICAL: the version slot a dashboard sits in is NOT stable. OO will
  # silently migrate a v5 payload to v6/v7/v8 on the next PUT (depending on
  # the server version that processed it). So we must look in EVERY version
  # slot AND at the top level for title + id; matching only on v5 misses
  # migrated dashboards and the next apply creates a duplicate.
  existing_id=$(jq -r --arg t "$title" '
    (if type == "array" then .
     elif has("list") then .list
     elif has("dashboards") then .dashboards
     else [] end)
    | map(select(
        .title == $t
        or (.v5 // .v4 // .v3 // .v2 // .v1 // .v6 // .v7 // .v8 // {}).title == $t
      ))
    | (.[0] // {})
    | (
        .dashboard_id
        // .dashboardId
        // .v8.dashboardId // .v7.dashboardId // .v6.dashboardId
        // .v5.dashboardId // .v4.dashboardId // .v3.dashboardId
        // .v2.dashboardId // .v1.dashboardId
        // ""
      )
  ' <<<"$LIST_RESPONSE")

  if [[ -n "$existing_id" && "$existing_id" != "null" ]]; then
    # Update path — pull hash from the current GET so the optimistic-
    # concurrency check on PUT succeeds.
    current=$(curl -sf -u "$EMAIL:$PASSWORD" \
      "$OO_BASE_URL/api/$OO_ORG/dashboards/$existing_id?folder=$OO_FOLDER" \
      -H 'Accept: application/json')
    hash=$(jq -r '
      .hash
      // .v8.hash // .v7.hash // .v6.hash
      // .v5.hash // .v4.hash // .v3.hash // .v2.hash // .v1.hash
      // ""
    ' <<<"$current")

    if [[ -z "$hash" || "$hash" == "null" ]]; then
      echo "    ⚠ no hash on existing dashboard $existing_id — falling back to PUT without hash"
      url="$OO_BASE_URL/api/$OO_ORG/dashboards/$existing_id?folder=$OO_FOLDER"
    else
      url="$OO_BASE_URL/api/$OO_ORG/dashboards/$existing_id?folder=$OO_FOLDER&hash=$hash"
    fi

    # Inject the existing id so the v5 payload matches what OO expects.
    payload=$(jq --arg id "$existing_id" '.dashboardId = $id' "$json_file")

    http_code=$(curl -sS -u "$EMAIL:$PASSWORD" \
      -H 'Content-Type: application/json' \
      -X PUT "$url" \
      --data-binary "$payload" \
      -o /tmp/oo-apply-resp.json \
      -w '%{http_code}')

    if [[ "$http_code" =~ ^2 ]]; then
      echo "    ✓ updated ($existing_id)"
    else
      echo "    ✗ PUT $http_code — $(jq -r '.message // .error // .' /tmp/oo-apply-resp.json 2>/dev/null || cat /tmp/oo-apply-resp.json)" >&2
      exit 1
    fi
  else
    # Create path. POST with the file as-is; server generates the ID.
    http_code=$(curl -sS -u "$EMAIL:$PASSWORD" \
      -H 'Content-Type: application/json' \
      -X POST "$OO_BASE_URL/api/$OO_ORG/dashboards?folder=$OO_FOLDER" \
      --data-binary @"$json_file" \
      -o /tmp/oo-apply-resp.json \
      -w '%{http_code}')

    if [[ "$http_code" =~ ^2 ]]; then
      new_id=$(jq -r '.dashboardId // .v5.dashboardId // .id // "?"' /tmp/oo-apply-resp.json)
      echo "    ✓ created ($new_id)"
    else
      echo "    ✗ POST $http_code — $(jq -r '.message // .error // .' /tmp/oo-apply-resp.json 2>/dev/null || cat /tmp/oo-apply-resp.json)" >&2
      exit 1
    fi
  fi
done

echo "✓ Dashboards in sync."

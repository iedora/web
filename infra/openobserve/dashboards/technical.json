  "tabs": [
    {
      "tabId": "request_path",
      "name": "Request path",
      "panels": [
        {
          "id": "p_http_p95",
          "type": "line",
          "title": "p95 HTTP request duration by route (15m)",
          "description": "Auto-instrumented by Next 16. Spike here = SLI breach for end-users.",
          "queryType": "sql",
          "layout": {
            "x": 0,
            "y": 0,
            "w": 12,
            "h": 6,
            "i": 1
          },
          "config": {
            "show_legends": true,
            "unit": "milliseconds",
            "base_map": {
              "type": "osm"
            },
            "map_view": {
              "zoom": 1,
              "lat": 0,
              "lng": 0
            }
          },
          "queries": [
            {
              "query": "SELECT histogram(_timestamp, '1 minute') AS x_axis_1, http_route AS breakdown_1, approx_percentile_cont(duration / 1000.0, 0.95) AS y_axis_1 FROM \"default\" WHERE service_name = 'iedora-menu' AND http_route IS NOT NULL GROUP BY x_axis_1, breakdown_1 ORDER BY x_axis_1",
              "customQuery": true,
              "fields": {
                "stream": "default",
                "stream_type": "traces",
                "x": [
                  {
                    "label": "Time",
                    "alias": "x_axis_1",
                    "column": "x_axis_1",
                    "color": null
                  }
                ],
                "y": [
                  {
                    "label": "p95 ms",
                    "alias": "y_axis_1",
                    "column": "y_axis_1",
                    "color": "#b25960",
                    "aggregationFunction": "p95"
                  }
                ],
                "breakdown": [
                  {
                    "label": "Route",
                    "alias": "breakdown_1",
                    "column": "breakdown_1",
                    "color": null
                  }
                ],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": ""
              }
            }
          ]
        },
        {
          "id": "p_error_rate",

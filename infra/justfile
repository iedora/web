# Shared infra workspace — Tofu-managed Hetzner box + containers.
#
# `just infra::deploy` runs ONE `tofu apply`. Tofu owns:
#   - Hetzner CAX11 VPS (provisioning + cloud-init Docker install)
#   - cross-product Cloudflare resources (R2 buckets, tunnels, DNS)
#   - Tailscale ACL + CI workload identity federation
#   - GitHub Actions secrets/variables reconciliation
#   - Every always-on Docker container on the Hetzner box (postgres,
#     openobserve, zitadel + login, backups, caddy, observability tunnel)
#   - Zitadel orgs/projects (after one-shot SA-key bootstrap, see below)
#   - The menu app container (docker_container.menu_web)

set dotenv-load := true

tofu := "bin/with-secrets tofu -chdir=tofu"

_default:
    @just --list --unsorted

# Apply every infra resource: Hetzner VPS + Cloudflare R2 + GitHub Actions
# config + all containers. Thin shim over the Go orchestrator at
# infra/cmd/iedora — every Pass 1/2/3 detail, the cert-ready probe, the
# DNS-override CONNECT proxy that sidesteps the macOS NXDOMAIN cache, and
# the BWS write-through of INFRA_HOST_IP all live there.
#
# Why Go (not bash): the inline bash for `deploy` + `destroy` had grown
# to a ~150-line octopus that nobody could change without breaking
# something three lines later. The Go port is type-checked, unit-tested
# (see `infra/cmd/iedora/*_test.go`), and contains the load-bearing
# fluency fixes from `docs/deploy-fluency-brief.md`:
#   - HTTPS_PROXY → localhost dns-override proxy for Pass 3 (bypasses
#     mDNSResponder NXDOMAIN cache for auth.iedora.com after IP churn).
#   - Cert-issuer check before declaring Zitadel ready (catches Caddy
#     mid-ACME serving its internal CA).
#   - Auto-scrub of the prior IP's ~/.ssh/known_hosts entry on destroy.
deploy:
    bin/iedora deploy

# Tear down EVERY Tofu-managed resource. Same orchestrator, see deploy
# above. The state-rm + placeholder-Zitadel + BWS-scrub logic the old
# bash carried lives in infra/cmd/iedora/destroy.go now.
destroy:
    bin/iedora destroy

# Preflight check — runs locally, no mutation. Verifies bws + tofu + ssh
# are on PATH, BWS auth works, and every required bootstrap secret is in
# the iedora-deploy project. Cheap to run before `deploy` if you're not
# sure the environment is set up.
doctor:
    bin/iedora doctor

# Stop + remove the Postgres container AND wipe its bind-mount data dir on
# the Hetzner box. Destructive: menu + zitadel databases all gone.
wipe-postgres:
    #!/usr/bin/env bash
    set -euo pipefail
    printf 'Type DELETE to wipe infra-postgres + its data dir: '
    read -r CONFIRM
    [ "$CONFIRM" = DELETE ] || { echo "aborted"; exit 1; }
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh "root@$HOST" 'docker rm -f infra-postgres 2>/dev/null; rm -rf /root/infra-postgres'
    echo "✓ infra-postgres + /root/infra-postgres removed. tofu apply to recreate."

# Tail logs of any infra container on the Hetzner box.
# Usage: `just infra::logs zitadel` (the recipe prefixes `infra-`).
logs svc="backups":
    #!/usr/bin/env bash
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh "root@$HOST" "docker logs -f --tail=200 infra-{{svc}}"

# psql shell into the live Postgres container.
console:
    #!/usr/bin/env bash
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh -t "root@$HOST" "docker exec -it infra-postgres psql -U postgres"

# Force a pg_dump now (the cron runs daily anyway).
backup:
    #!/usr/bin/env bash
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh "root@$HOST" "docker exec infra-backups sh /backup.sh"

# Restore latest dump (interactive).
restore:
    #!/usr/bin/env bash
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh -t "root@$HOST" "docker exec -it infra-backups sh /restore.sh"

# Rebuild + push the backup container image (only when bumping Postgres major).
build-backup:
    #!/usr/bin/env bash
    set -euo pipefail
    TOKEN=$(bin/with-secrets bash -c 'printf "%s" "${INFRA_GHCR_TOKEN:-$(gh auth token)}"')
    echo "Logging into GHCR..."
    printf "%s" "$TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin
    echo "Building + pushing ghcr.io/$GHCR_USER/iedora-backup:18..."
    docker buildx build --platform linux/amd64 \
      --tag "ghcr.io/$GHCR_USER/iedora-backup:18" --push backup

# Rotate one BWS secret. Usage: just rotate-secret INFRA_HCLOUD_TOKEN
#
# For AUTOGEN_INFRA_* secrets (Tofu-minted): DON'T edit them in BWS.
# Instead: `bin/with-secrets tofu -chdir=tofu apply -replace=random_password.<name>`
# triggers a fresh random_password, and the null_resource.bws_sync_autogen
# write-through pushes the new value to BWS. Read the constraints below
# before rotating any AUTOGEN_INFRA_* key.
rotate-secret key:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "{{key}}" == AUTOGEN_* ]]; then
      echo "{{key}} is Tofu-minted. Rotate via:"
      echo "  bin/with-secrets tofu -chdir=tofu apply -replace=random_password.<name>"
      echo "Names: postgres, backup_passphrase, zitadel_masterkey, zitadel_first_admin, openobserve_password"
      exit 1
    fi
    if [ -z "${BWS_PROJECT_ID:-}" ]; then
      BWS_PROJECT_ID=$(bws project list -o json | jq -r '.[] | select(.name=="iedora-deploy") | .id')
    fi
    SECRET_ID=$(bws secret list "$BWS_PROJECT_ID" -o json | jq -r '.[] | select(.key=="{{key}}") | .id')
    [ -n "$SECRET_ID" ] || { echo "No BWS secret named {{key}} in project"; exit 1; }
    printf "New value for {{key}} (no echo): "
    stty -echo; read -r NEW; stty echo; printf "\n"
    [ -n "$NEW" ] || { echo "Empty value, aborting"; exit 1; }
    bws secret edit "$SECRET_ID" --value "$NEW" -o none
    echo "✓ {{key}} rotated in BWS"
    echo "→ AUTOGEN_INFRA_POSTGRES_PASSWORD: tofu apply -replace recreates infra-postgres + zitadel + backups with new password; menu needs its own redeploy"
    echo "→ AUTOGEN_INFRA_BACKUP_PASSPHRASE: invalidates ALL historical dumps; don't rotate casually — see docs/secrets.md for the dual-passphrase window"
    echo "→ AUTOGEN_INFRA_OPENOBSERVE_ROOT_USER_PASSWORD: tofu apply recreates infra-openobserve; every product needs a redeploy (OTEL_EXPORTER_OTLP_HEADERS depends on it)"
    echo "→ AUTOGEN_INFRA_ZITADEL_MASTERKEY: lifecycle.prevent_destroy guards it; rotating renders the encrypted projection table unreadable — only via the documented re-key flow"
    echo "→ AUTOGEN_INFRA_ZITADEL_FIRST_ADMIN_PASSWORD: only used on FIRST boot; rotate the live password via the Zitadel UI instead"
    echo "→ INFRA_HCLOUD_TOKEN: regenerate in Hetzner console + push; 'just infra::deploy' next run uses the new token. Zero-downtime."

# Fetch the zitadel-admin-sa JSON key minted by FirstInstance and upload
# to BWS. Run ONCE after the first `just infra::deploy` (or after a
# `just infra::zitadel-rebootstrap`). Subsequent `just infra::deploy`
# runs see the SA key in BWS, activate the zitadel TF provider, and
# import the iedora org + project declaratively.
zitadel-fetch-sa-key:
    #!/usr/bin/env bash
    set -euo pipefail
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    echo "Waiting for FirstInstance to write /zitadel-bootstrap/zitadel-admin-sa.json..."
    for i in $(seq 1 60); do
      if ssh "root@$HOST" 'docker run --rm -v zitadel-bootstrap:/x busybox test -s /x/zitadel-admin-sa.json' 2>/dev/null; then
        break
      fi
      [ $i -eq 60 ] && { echo "✗ Timeout — zitadel-admin-sa.json never appeared. Check infra-zitadel logs."; exit 1; }
      sleep 5
    done
    KEY=$(ssh "root@$HOST" 'docker run --rm -v zitadel-bootstrap:/x busybox cat /x/zitadel-admin-sa.json')
    [ -n "$KEY" ] || { echo "✗ Fetched key was empty"; exit 1; }
    bin/with-secrets bash -c "
      SECRET_ID=\$(bws secret list \"\$BWS_PROJECT_ID\" -o json \
        | jq -r '.[] | select(.key==\"INFRA_ZITADEL_SA_KEY_JSON\") | .id')
      if [ -n \"\$SECRET_ID\" ]; then
        bws secret edit \"\$SECRET_ID\" --value '$KEY' -o none
      else
        bws secret create -o none -- INFRA_ZITADEL_SA_KEY_JSON '$KEY' \"\$BWS_PROJECT_ID\"
      fi
    "
    echo "✓ INFRA_ZITADEL_SA_KEY_JSON in BWS. Next 'just infra::deploy' will land the zitadel.tf resources."

# Drop + re-bootstrap Zitadel: wipes the `zitadel` Postgres DB and the
# `zitadel-bootstrap` Docker volume, then runs apply → FirstInstance →
# fetch-sa-key → apply (lands TF resources).
zitadel-rebootstrap:
    #!/usr/bin/env bash
    set -euo pipefail
    printf 'Type REBOOTSTRAP to wipe Zitadel DB + bootstrap volume: '
    read -r CONFIRM
    [ "$CONFIRM" = REBOOTSTRAP ] || { echo "aborted"; exit 1; }
    HOST=$({{tofu}} output -raw hetzner_ipv4)

    bin/with-secrets bash -c '
      SECRET_ID=$(bws secret list "$BWS_PROJECT_ID" -o json \
        | jq -r ".[] | select(.key==\"INFRA_ZITADEL_SA_KEY_JSON\") | .id")
      [ -n "$SECRET_ID" ] && bws secret delete "$SECRET_ID" -o none || true
    '

    ssh "root@$HOST" '
      docker rm -f infra-zitadel-login infra-zitadel 2>/dev/null || true
      docker exec infra-postgres psql -U postgres -c "DROP DATABASE IF EXISTS zitadel WITH (FORCE);"
      docker exec infra-postgres psql -U postgres -c "CREATE DATABASE zitadel;"
      docker volume rm zitadel-bootstrap 2>/dev/null || true
    '

    # Defensive state-rm — any zitadel_* resources point at IDs that no
    # longer exist after the wipe.
    bin/with-secrets bash -c '
      {{tofu}} state list 2>/dev/null \
        | grep "^zitadel_" \
        | xargs -r -n1 {{tofu}} state rm
    ' || true

    just deploy
    just zitadel-fetch-sa-key
    just deploy
    echo "✓ Zitadel re-bootstrapped. zitadel.tf resources landed declaratively."

# Tail the live OpenObserve binary's logs (UI + OTLP receiver, port 5080).
observability-logs:
    #!/usr/bin/env bash
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh "root@$HOST" "docker logs -f --tail=200 infra-openobserve"

# Drop into the OpenObserve container shell.
observability-console:
    #!/usr/bin/env bash
    HOST=$({{tofu}} output -raw hetzner_ipv4)
    ssh -t "root@$HOST" "docker exec -it infra-openobserve /bin/sh"

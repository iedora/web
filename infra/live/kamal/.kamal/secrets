# Secrets locais. SOPS encriptado em ~/.config/iedora/secrets.sops.yaml,
# decrypt key em ~/.config/sops/age/keys.txt.
#
# Kamal exige que cada secret declarado em deploy.yml (env.secret /
# accessories) tenha entry aqui — injectado em runtime, nunca persiste
# no Beelink fora do container env.

SOPS_FILE=$HOME/.config/iedora/secrets.sops.yaml
export SOPS_AGE_KEY_FILE=$HOME/.config/sops/age/keys.txt

# GHCR auth via gh CLI (scopes write:packages + read:packages).
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# CF tunnel token escrito por `tofu apply` (infra/outputs.tf).
TUNNEL_TOKEN=$(cat infra/live/tofu/.tunnel-token)

# R2 S3 creds — criadas por `tofu apply` (cloudflare_api_token + sha256).
S3_ACCESS_KEY=$(cat infra/live/tofu/.s3-access-key)
S3_SECRET_KEY=$(cat infra/live/tofu/.s3-secret-key)

# App
CORE_SECRET=$(sops -d --extract '["CORE_SECRET"]' $SOPS_FILE)
MOONSHOT_API_KEY=$(sops -d --extract '["MOONSHOT_API_KEY"]' $SOPS_FILE)

# Postgres accessory — hostname = iedora-web-postgres na kamal network.
POSTGRES_PASSWORD=$(sops -d --extract '["POSTGRES_PASSWORD"]' $SOPS_FILE)
CORE_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@iedora-web-postgres:5432/core
MENU_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@iedora-web-postgres:5432/menu
IMOPUSH_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@iedora-web-postgres:5432/imopush

# OpenObserve accessory — admin password + header Basic para o collector
# (Authorization: Basic base64(email:password)).
ZO_ROOT_USER_PASSWORD=$(sops -d --extract '["OPENOBSERVE_ADMIN_PASSWORD"]' $SOPS_FILE)
OTEL_AUTH_HEADER="Basic $(printf '%s' "eduardoferdcarvalho@gmail.com:${ZO_ROOT_USER_PASSWORD}" | base64)"

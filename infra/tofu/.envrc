# Tofu env for all sub-stacks under infra/tofu/.
# Sourced manually (`. .envrc`) or auto-loaded if direnv is installed
# (`direnv allow` once per machine after pulling).
#
# Cross-repo dep: homelab-iac owns the platform secrets we read
# (CF API token, R2 state-backend creds, tofu state passphrase) and the
# R2_ACCOUNT_ID identifier. We just re-export them under TF_VAR_* + AWS_*.
#
# Override the default path if your homelab-iac checkout lives elsewhere:
#   export HOMELAB_IAC_ROOT=/path/to/homelab-iac
# Otherwise we assume side-by-side checkouts under ~/projects/personal/.

HOMELAB_IAC_ROOT="${HOMELAB_IAC_ROOT:-$HOME/projects/personal/homelab-iac}"

if [ ! -f "$HOMELAB_IAC_ROOT/tools/lib/common.sh" ]; then
  echo "homelab-iac/tools/lib/common.sh not found at $HOMELAB_IAC_ROOT/tools/lib/common.sh" >&2
  echo "  • clone:        git clone https://github.com/eduvhc/homelab-iac.git $HOMELAB_IAC_ROOT" >&2
  echo "  • bootstrap:    add age key at ~/.config/sops/age/keys.txt + run $HOMELAB_IAC_ROOT/tools/seed-secrets.sh" >&2
  echo "  • or override:  export HOMELAB_IAC_ROOT=/different/path" >&2
  return 1 2>/dev/null || exit 1
fi

# homelab-iac's common.sh exposes source_envrc, which decrypts sops + exports
# everything we need, including:
#   - TF_VAR_tf_state_passphrase / TF_VAR_cf_api_token / TF_VAR_r2_account_id
#   - AWS_{ACCESS_KEY_ID,SECRET_ACCESS_KEY,REGION,ENDPOINT_URL_S3} for state backend
# Export REPO_ROOT before sourcing — inline `VAR=val .` doesn't propagate to
# the dot-sourced file in bash. Subshells/direnv contain the leak naturally.
export REPO_ROOT="$HOMELAB_IAC_ROOT"
. "$HOMELAB_IAC_ROOT/tools/lib/common.sh"
source_envrc

# Deploy-time config for the shared infra workspace (Postgres + backups).
# Copy to `infra/.env` (gitignored).
#
# All PRODUCTION SECRETS live in Bitwarden Secrets Manager (project
# iedora-deploy) — this file holds only non-secret config + the BWS access
# token that unlocks the vault. Same model as products/menu/infra/.env.

# Cloudflare account ID — dashboard → right sidebar. Used by the R2 backup
# bucket's Tofu root.
CLOUDFLARE_ACCOUNT_ID=

# Homelab / cloud box. Tofu's docker provider connects as root with
# SSH-key-only login (same key as ad-hoc operator ssh).
ONPREM_HOST=

# GitHub Container Registry — your GH username; backup accessory image
# pushed to ghcr.io/$GHCR_USER/iedora-backup.
GHCR_USER=

# OpenObserve R2 bucket name (must match observability_bucket_name in
# tofu/variables.tf). The Tofu-managed infra-openobserve container reads
# this directly. Default `iedora-observability` is fine; only change if
# renaming the bucket.
OPENOBSERVE_BUCKET_NAME=iedora-observability

# Bitwarden Secrets Manager — the ONE secret on disk. Shared with menu
# and genkan (same project, same machine account). See products/menu/infra
# /.env.example for the one-time setup steps.
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=

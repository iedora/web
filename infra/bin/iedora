#!/usr/bin/env bash
# Transparent wrapper for the Go iedora command at infra/cmd/iedora.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# As of the stage-filter refactor, this wrapper does NOT layer
# `bin/with-secrets` automatically. The Taskfile (or a CI workflow, or
# the operator) is responsible for choosing the right `--stage` for the
# subcommand being invoked:
#
#   task infra:up    → with-secrets --stage iac    -- bin/iedora iac apply
#   task app:apply   → with-secrets --stage app    -- bin/iedora app apply
#   task deploy:menu → with-secrets --stage deploy --product menu -- bin/iedora deploy menu
#
# `bin/iedora doctor` and `bin/iedora --help` run fine without
# with-secrets — they only need BWS_ACCESS_TOKEN which the operator's
# shell already exports. Other subcommands should go through `task`.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_DIR="$(dirname "$DIR")"

exec go run -C "$INFRA_DIR" ./cmd/iedora "$@"

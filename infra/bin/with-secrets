#!/bin/sh
# Wrap a command with secrets fetched from Bitwarden Secrets Manager,
# then exec the command in-place. Same pattern as the product wrappers
# (kept duplicated, not symlinked, so infra/ is independently appliable).
#
# Requires (from infra/.env):
#   BWS_ACCESS_TOKEN          machine-account token
#   BWS_PROJECT_ID            project UUID (iedora-deploy)
#   CLOUDFLARE_ACCOUNT_ID     for the R2 bucket Tofu root
#
# Usage:
#   infra/bin/with-secrets <cmd> [args...]
set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ENV_FILE="$SCRIPT_DIR/../.env"
if [ -f "$ENV_FILE" ] && [ -z "${BWS_ACCESS_TOKEN:-}" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

: "${BWS_ACCESS_TOKEN:?infra/.env missing BWS_ACCESS_TOKEN}"
: "${BWS_PROJECT_ID:?infra/.env missing BWS_PROJECT_ID}"

# Load every BWS secret as an env var. macOS bash 3.2 mangles multi-line
# single-quoted strings inside `eval` in subtle ways (JSON `\n` escapes get
# resolved into real newlines mid-eval and the line terminates early —
# "RSA: command not found" symptom). We materialize the env to a tempfile
# via python's shlex.quote (POSIX-safe single-quoting) and source it. No
# eval. Plays nice with bash 3.2 + dash + zsh.
TMPENV=$(mktemp -t bws-env.XXXXXX)
trap 'rm -f "$TMPENV"' EXIT
bws secret list "$BWS_PROJECT_ID" -o json \
  | python3 "$SCRIPT_DIR/_bws-to-env.py" > "$TMPENV" \
  || { echo "with-secrets: BWS fetch/parse failed" >&2; exit 1; }
# shellcheck disable=SC1090
. "$TMPENV"

# TF_VAR_* aliases — Tofu reads inputs from these specific names. The
# infra Tofu root needs the Cloudflare bootstrap (for R2) and the GitHub
# PAT (to reconcile the repo's Actions secrets + variables).
export TF_VAR_account_id="${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID missing}"
export TF_VAR_cloudflare_api_token="${INFRA_CLOUDFLARE_API_TOKEN:?INFRA_CLOUDFLARE_API_TOKEN missing in BWS}"
export TF_VAR_state_passphrase="${INFRA_STATE_PASSPHRASE:?INFRA_STATE_PASSPHRASE missing in BWS}"

# GitHub repo config. The PAT lives in BWS; the BWS access token + project
# UUID are passed through as-is so Tofu can declare them as the GHA secrets
# the runners read.
export TF_VAR_github_token="${INFRA_GITHUB_API_TOKEN:?INFRA_GITHUB_API_TOKEN missing in BWS}"
export TF_VAR_bws_access_token="$BWS_ACCESS_TOKEN"
export TF_VAR_bws_project_id="$BWS_PROJECT_ID"
export TF_VAR_kamal_ssh_private_key="${INFRA_KAMAL_SSH_PRIVATE_KEY:?INFRA_KAMAL_SSH_PRIVATE_KEY missing in BWS}"
export TF_VAR_claude_code_oauth_token="${INFRA_CLAUDE_CODE_OAUTH_TOKEN:?INFRA_CLAUDE_CODE_OAUTH_TOKEN missing in BWS}"

# Hetzner Cloud — the API token that provisions the VPS hosting every infra
# container. After Hetzner is up the docker provider connects via SSH to
# `hcloud_server.iedora.ipv4_address` directly (no infra/.env ONPREM_HOST
# needed; the Tofu output is the source of truth).
export TF_VAR_infra_hcloud_token="${INFRA_HCLOUD_TOKEN:?INFRA_HCLOUD_TOKEN missing in BWS — sign up at hetzner.com/cloud + create a Read/Write API token under the iedora project}"

# Per-container secrets — inputs to `docker_container` resources in
# infra/tofu/containers.tf.
export TF_VAR_infra_postgres_password="${INFRA_POSTGRES_PASSWORD:?INFRA_POSTGRES_PASSWORD missing in BWS}"
export TF_VAR_infra_backup_passphrase="${INFRA_BACKUP_PASSPHRASE:?INFRA_BACKUP_PASSPHRASE missing in BWS}"
export TF_VAR_infra_ghcr_token="${INFRA_GHCR_TOKEN:?INFRA_GHCR_TOKEN missing in BWS}"
export TF_VAR_infra_openobserve_root_user_email="${INFRA_OPENOBSERVE_ROOT_USER_EMAIL:?INFRA_OPENOBSERVE_ROOT_USER_EMAIL missing in BWS}"
export TF_VAR_infra_openobserve_root_user_password="${INFRA_OPENOBSERVE_ROOT_USER_PASSWORD:?INFRA_OPENOBSERVE_ROOT_USER_PASSWORD missing in BWS}"
export TF_VAR_infra_zitadel_masterkey="${INFRA_ZITADEL_MASTERKEY:?INFRA_ZITADEL_MASTERKEY missing in BWS}"
export TF_VAR_infra_zitadel_first_admin_password="${INFRA_ZITADEL_FIRST_ADMIN_PASSWORD:?INFRA_ZITADEL_FIRST_ADMIN_PASSWORD missing in BWS}"

# Menu app secrets — consumed by docker_container.menu_web in containers.tf
# (replaced Kamal-managed menu-web on 2026-05-20).
export TF_VAR_menu_auth_secret="${MENU_AUTH_SECRET:?MENU_AUTH_SECRET missing in BWS}"
export TF_VAR_menu_oauth_client_id="${MENU_OAUTH_CLIENT_ID:?MENU_OAUTH_CLIENT_ID missing in BWS}"
export TF_VAR_menu_oauth_client_secret="${MENU_OAUTH_CLIENT_SECRET:?MENU_OAUTH_CLIENT_SECRET missing in BWS}"
export TF_VAR_infra_menu_assets_access_key="${INFRA_MENU_ASSETS_ACCESS_KEY:?INFRA_MENU_ASSETS_ACCESS_KEY missing in BWS}"
export TF_VAR_infra_menu_assets_secret_key="${INFRA_MENU_ASSETS_SECRET_KEY:?INFRA_MENU_ASSETS_SECRET_KEY missing in BWS}"
export TF_VAR_infra_menu_assets_endpoint="${INFRA_MENU_ASSETS_ENDPOINT:?INFRA_MENU_ASSETS_ENDPOINT missing in BWS}"
export TF_VAR_infra_menu_assets_bucket="${INFRA_MENU_ASSETS_BUCKET:?INFRA_MENU_ASSETS_BUCKET missing in BWS}"
export TF_VAR_infra_openobserve_ingest_header="${INFRA_OPENOBSERVE_INGEST_HEADER:?INFRA_OPENOBSERVE_INGEST_HEADER missing in BWS}"

# Zitadel TF-provider service-account key. FirstInstance writes
# /zitadel-bootstrap/zitadel-admin-sa.json on the first Zitadel boot; the
# `just infra::zitadel-rebootstrap` recipe fetches the file via the Tofu
# output `hetzner_ipv4` and uploads to BWS. From then on this var flows
# BWS → TF_VAR_infra_zitadel_sa_key_json → provider.jwt_profile_json.
#
# An empty value here means "Zitadel hasn't been bootstrapped yet OR the
# server hasn't been provisioned" — the zitadel.tf provider block is gated
# on the var being non-empty so an empty value is a no-op rather than an
# apply error. Initial bootstrap is therefore a two-pass apply:
#   1. tofu apply (server + containers; SA key file appears on volume)
#   2. just infra::zitadel-rebootstrap-fetch (uploads SA key to BWS)
#   3. tofu apply (zitadel.tf provider activates, org/project resources land)
export TF_VAR_infra_zitadel_sa_key_json="${INFRA_ZITADEL_SA_KEY_JSON:-}"

exec "$@"

#!/usr/bin/env bash
# Local deploy do Mac — SSH-trigger ao Kamal no Beelink. O Beelink
# faz `git fetch + checkout <SHA> + kamal deploy`. Sem rsync, sem
# build local.
#
# Pré-requisitos (one-time):
#   - `./homelab-core-infra/up.sh --host ssh://root@192.168.50.53
#      --bootstrap-ci` instalou Kamal + clonou /opt/iedora + criou
#      /root/.netrc com PAT para git auth
#   - SSH key autorizada em root@homelab (~/.ssh/iedora-homelab-*)
#   - BWS_ACCESS_TOKEN exportado (Kamal lê secrets de produção)
#   - KAMAL_REGISTRY_PASSWORD exportado (PAT do operador, write:package)
#   - Commit (e idealmente push) do SHA que queres deployar — o
#     Beelink só consegue checkout SHAs que já estejam em origin
#
# Uso:
#   export KAMAL_REGISTRY_PASSWORD='<PAT>'
#   export BWS_ACCESS_TOKEN='<token>'
#   ./bin/deploy

set -euo pipefail

HOST="${KAMAL_HOST:-192.168.50.53}"
SSH_KEY="${HOMELAB_SSH_KEY:-$HOME/.ssh/iedora-homelab-$(scutil --get LocalHostName 2>/dev/null || hostname -s)}"

: "${KAMAL_REGISTRY_PASSWORD:?export-o-PAT-do-Gitea-com-scope-write:package}"
: "${BWS_ACCESS_TOKEN:?export-o-BWS_ACCESS_TOKEN}"

[ -f "$SSH_KEY" ] || { echo "✗ SSH key não encontrada: $SSH_KEY"; exit 1; }
command -v git >/dev/null || { echo "✗ git não instalado"; exit 1; }

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SHA="$(cd "$REPO_ROOT" && git rev-parse HEAD)"

echo "→ ssh root@$HOST: checkout $SHA + kamal deploy"
ssh -i "$SSH_KEY" "root@$HOST" bash <<EOF
set -e
cd /opt/iedora
git fetch origin
git checkout '$SHA'
export BWS_ACCESS_TOKEN='$BWS_ACCESS_TOKEN'
export KAMAL_REGISTRY_PASSWORD='$KAMAL_REGISTRY_PASSWORD'
kamal lock release -d production || true
# Sem --version: Kamal lê HEAD do /opt/iedora após o checkout.
kamal deploy -d production
EOF

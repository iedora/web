#!/bin/bash
# dev-stack — local development stack orchestrator.
#
# Thin bash shim over docker compose. Boots postgres, adobe/s3mock,
# openobserve, menu; runs core migrations; composes apps/web/.env.
# Compatible with bash 3.2+ (macOS system bash).
#
# See docs/dev.md.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
REPO_ROOT="$(dirname "${SCRIPT_DIR}")"
readonly REPO_ROOT

# ── constants ──────────────────────────────────────────────────────────

readonly COMPOSE_FILE="${REPO_ROOT}/dev/docker-compose.yml"
readonly ENV_FILE="${REPO_ROOT}/apps/web/.env"
readonly ENV_LOCAL="${REPO_ROOT}/apps/web/.env.local"
readonly COMPOSE_ENV="${REPO_ROOT}/dev/.env"

# ── helpers ────────────────────────────────────────────────────────────

# Usage: deps_of <service>
# Outputs space-separated dependency names.
deps_of() {
  case "$1" in
    postgres)    ;;
    s3mock)      ;;
    openobserve) printf '%s' "s3mock" ;;
    web)         printf '%s' "postgres s3mock openobserve" ;;
    *)           return 1 ;;
  esac
}

# Usage: service_known <name>
# Returns 0 if name is a recognised service.
service_known() {
  case "$1" in
    postgres|s3mock|openobserve|web) return 0 ;;
    *) return 1 ;;
  esac
}

# Usage: step <n> <label>
step() { printf '[dev] [%s] %s\n' "$1" "$2"; }

# Usage: err <message>
err() { printf '[dev] ✗ %s\n' "$1" >&2; }

# Usage: has_profile <name>
# Returns 0 if name is in PROFILE_NAMES.
has_profile() {
  local name
  for name in "${PROFILE_NAMES[@]}"; do
    [[ "${name}" == "$1" ]] && return 0
  done
  return 1
}

# Usage: trim <string>
# Strips leading/trailing whitespace via stdin→stdout.
trim() { sed 's/^[[:space:]]*//;s/[[:space:]]*$//'; }

# ── s3mock port (from dev/.env, default 9090) ──────────────────────────

s3mock_port() {
  local port=9090
  if [[ -f "${COMPOSE_ENV}" ]]; then
    port="$(sed -n 's/^S3MOCK_HTTP_PORT=//p' "${COMPOSE_ENV}" | head -1)"
    [[ -z "${port}" ]] && port=9090
  fi
  printf '%s' "${port}"
}

# ── usage ──────────────────────────────────────────────────────────────

usage() {
  cat >&2 <<'EOF'
Usage: bin/dev-stack [flags]

  --only svc,...     Start only these services (+ deps):
                       postgres, s3mock, openobserve, menu
  --except svc,...   Start everything except these
  --destroy          Tear down: docker compose down -v (preserves .env.local)
  --reset-db name    Drop + recreate one database (menu|core)

With no flags, boots the full stack + migrations + .env.
EOF
  exit 2
}

# ── --destroy ──────────────────────────────────────────────────────────

cmd_destroy() {
  step 1 "docker compose down -v --remove-orphans"
  docker compose --profile '*' -f "${COMPOSE_FILE}" down -v --remove-orphans 2>/dev/null || true
  printf '[dev] ✓ destroyed (volumes + containers removed)\n'
  printf '[dev] → .env.local preserved — delete it manually if you want a fresh CORE_SECRET\n'
}

# ── --reset-db ─────────────────────────────────────────────────────────

cmd_reset_db() {
  local name="$1"
  case "${name}" in
    menu|core)
      printf '[dev] reset-db: dropping + recreating %s\n' "${name}"
      docker exec -i infra-postgres psql -U postgres -d postgres \
        -c "DROP DATABASE IF EXISTS ${name};" >/dev/null 2>&1
      docker exec -i infra-postgres psql -U postgres -d postgres \
        -c "CREATE DATABASE ${name};" >/dev/null 2>&1
      [[ "${name}" == "core" ]] && printf '[dev] ✓ re-run bin/dev-stack to re-apply auth migrations\n'
      ;;
    *) err "--reset-db: unknown db '${name}' (want menu|core)"; exit 1 ;;
  esac
}

# ── profile resolution ─────────────────────────────────────────────────

resolve_profiles() {
  local only="${1:-}"
  local except="${2:-}"
  PROFILE_NAMES=()

  if [[ -n "${only}" ]]; then
    local old_ifs="${IFS}"; IFS=',' read -ra names <<< "${only}"; IFS="${old_ifs}"
    local n d
    for n in "${names[@]}"; do
      n="$(printf '%s' "${n}" | trim)"
      service_known "${n}" || { err "unknown service '${n}'"; exit 1; }
      [[ " ${PROFILE_NAMES[*]} " != *" ${n} "* ]] && PROFILE_NAMES+=("${n}")
      for d in $(deps_of "${n}"); do
        [[ " ${PROFILE_NAMES[*]} " != *" ${d} "* ]] && PROFILE_NAMES+=("${d}")
      done
    done
  elif [[ -n "${except}" ]]; then
    local old_ifs="${IFS}"; IFS=',' read -ra skip <<< "${except}"; IFS="${old_ifs}"
    local s x keep
    for s in postgres s3mock openobserve web; do
      keep=1
      for x in "${skip[@]}"; do
        [[ "$(printf '%s' "${x}" | trim)" == "${s}" ]] && keep=0
      done
      if (( keep )); then PROFILE_NAMES+=("${s}"); fi
    done
  else
    PROFILE_NAMES=(postgres s3mock openobserve web)
  fi
}

# ── docker compose helpers ─────────────────────────────────────────────

compose_up() {
  local profiles=("$@")
  local args=()
  for p in "${profiles[@]}"; do args+=(--profile "${p}"); done
  docker compose "${args[@]}" -f "${COMPOSE_FILE}" up -d --wait
}

# compose_up_build — `compose up --build` for the given profiles.
# Forces BuildKit to (re)build any service with a `build:` block
# (today only `web`). Use this when source changed; for the no-op path
# prefer plain compose_up so the running container isn't recreated.
#
# apps/web/.env is in the build context (the global `**/.env*`
# exclusion in .dockerignore is overridden by a targeted
# `!apps/web/.env` line) so Next inlines its NEXT_PUBLIC_* values
# into the client bundle automatically — no build args, no shell
# sourcing needed here.
compose_up_build() {
  local profiles=("$@")
  local args=()
  for p in "${profiles[@]}"; do args+=(--profile "${p}"); done
  docker compose "${args[@]}" -f "${COMPOSE_FILE}" up -d --wait --build
}

# ── web source fingerprint ─────────────────────────────────────────────
# Idempotency lever for step 4. `docker compose up --build` always
# recreates the container (BuildKit re-emits the image manifest even
# when every layer is a cache hit), so calling it unconditionally turns
# a no-op run into a ~9s recreate cycle. Instead, fingerprint the inputs
# that actually flow into the web image (tracked + untracked-not-ignored
# files under apps/web, packages, products, plus bun.lock) and only
# rebuild when the fingerprint changes; otherwise plain compose up is a
# true no-op against an already-healthy container.
#
# Sentinel lives under dev/ (gitignored). Hash uses git ls-files so the
# file set matches what the Docker build context will see (.dockerignore
# and .gitignore intersect closely enough for dev purposes; missing the
# odd untracked file means at worst one extra rebuild).
WEB_HASH_FILE="${REPO_ROOT}/dev/.web-build-hash"

web_sources_hash() {
  (
    cd "${REPO_ROOT}"
    git ls-files apps/web packages products bun.lock
    git ls-files --others --exclude-standard apps/web packages products
  ) \
    | grep -v -E '(^|/)\.env(\..*)?$' \
    | LC_ALL=C sort -u \
    | xargs -I{} shasum -a 256 "{}" | shasum -a 256 | awk '{print $1}'
}

# web_needs_rebuild — 0 (true) if the fingerprint differs from the
# stored sentinel, 1 (false) otherwise. Always rebuild if the image
# doesn't exist yet.
web_needs_rebuild() {
  if ! docker image inspect iedora-web:local >/dev/null 2>&1; then
    return 0
  fi
  [[ ! -f "${WEB_HASH_FILE}" ]] && return 0
  local now stored
  now="$(web_sources_hash)"
  stored="$(cat "${WEB_HASH_FILE}")"
  [[ "${now}" != "${stored}" ]]
}

web_record_hash() {
  mkdir -p "$(dirname "${WEB_HASH_FILE}")"
  web_sources_hash > "${WEB_HASH_FILE}"
}

# ── compose .env ───────────────────────────────────────────────────────
# Delegated to `iedora local env` so the topology (surface URLs +
# CSRF allowlist env names) has a single source of truth at
# infra/deploy/cmd/iedora/{topology,runtime_local}.go. Tofu outputs
# (Stage 4 prod env) consume the same registry.

compose_env_file() {
  go run "${REPO_ROOT}/infra/deploy/cmd/iedora" local env \
    --out "${ENV_FILE}" \
    --local "${ENV_LOCAL}" \
    --compose-env "${COMPOSE_ENV}"
}

# ── print summary ──────────────────────────────────────────────────────

print_done() {
  printf '\n[dev] ✓ local stack ready\n'
  if has_profile web; then
    printf '  → web      http://localhost:3000\n'
  else
    printf '  → web      not in selection (HMR path: cd apps/web && bun run dev)\n'
  fi
  has_profile openobserve \
    && printf '  → o2       http://localhost:5080  (dev@iedora.local / Password1!)\n'
}

# ── args ───────────────────────────────────────────────────────────────

parse_args() {
  ONLY='' EXCEPT='' DESTROY='' RESET_DB=''
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --only)    ONLY="$2"; shift 2 ;;
      --except)  EXCEPT="$2"; shift 2 ;;
      --destroy) DESTROY=1; shift ;;
      --reset-db) RESET_DB="$2"; shift 2 ;;
      -h|--help) usage ;;
      *)         err "Unknown: $1"; usage ;;
    esac
  done
  if [[ -n "${ONLY:-}${EXCEPT:-}" && -n "${ONLY:-}" && -n "${EXCEPT:-}" ]]; then
    err "--only and --except are mutually exclusive"; exit 1
  fi
}

# ── main ───────────────────────────────────────────────────────────────

# GLOBAL: PROFILE_NAMES — resolved service list populated by main().
declare -a PROFILE_NAMES

main() {
  parse_args "$@"

  if [[ -n "${DESTROY:-}" ]]; then
    cmd_destroy; exit 0
  fi

  if [[ -n "${RESET_DB:-}" ]]; then
    cmd_reset_db "${RESET_DB}"; exit 0
  fi

  resolve_profiles "${ONLY:-}" "${EXCEPT:-}"
  printf '[dev] selection: %s\n' "${PROFILE_NAMES[*]}"

  # infra = everything except web
  local infra=() p
  for p in "${PROFILE_NAMES[@]}"; do
    [[ "${p}" != "web" ]] && infra+=("${p}")
  done

  step 1 "docker compose up — infra services"
  compose_up "${infra[@]}"

  if has_profile postgres; then
    step 2 "apply DB migrations (core + per-product, via migrate container)"
    # Mirror prod Stage 3 exactly: build the dedicated migrate image
    # (infra/migrate/Dockerfile) and `docker run --rm` it on the
    # `iedora` network — same image, same entrypoint layout, same env
    # shape as `iedora app apply` would on Hetzner. Source of truth for
    # the product list lives in infra/deploy/cmd/iedora/local_migrate.go
    # (localMigrators slice); adding a new product is one entry there
    # + the usual products/<p>/scripts/migrate.mjs.
    "${REPO_ROOT}/bin/iedora" local migrate --repo "${REPO_ROOT}"
  fi

  step 3 "compose apps/web/.env"
  compose_env_file

  if has_profile web; then
    # All profiles in scope so the `depends_on: postgres` chain
    # resolves (compose errors when a depended-on service is filtered
    # out of the active profile selection, even if it's already
    # running). Infra services are idempotent — no-op since step 1.
    if web_needs_rebuild; then
      step 4 "docker compose up — web (source changed, rebuilding)"
      compose_up_build "${PROFILE_NAMES[@]}"
      web_record_hash
    else
      step 4 "docker compose up — web (source unchanged, skip build)"
      compose_up "${PROFILE_NAMES[@]}"
    fi
  fi

  print_done
}

main "$@"

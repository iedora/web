{
  "name": "@iedora/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache",
    "typecheck": "tsgo --build",
    "test": "echo 'unit tests live in products/ and packages/'",
    "build:test": "bun --env-file=.env.test next build",
    "test:e2e": "bun --env-file=.env.test playwright test",
    "test:e2e:ui": "bun --env-file=.env.test playwright test --ui",
    "test:e2e:debug": "PWDEBUG=1 bun --env-file=.env.test playwright test",
    "db:migrate:test": "bun --env-file=.env.test scripts/migrate-test.mjs"
  },
  "dependencies": {
    "@iedora/auth": "workspace:*",
    "@iedora/billing": "workspace:*",
    "@iedora/brand": "workspace:*",
    "@iedora/core-tenancy": "workspace:*",
    "@iedora/design-system": "workspace:*",
    "@iedora/observability": "workspace:*",
    "@iedora/product-core": "workspace:*",
    "@iedora/product-imopush": "workspace:*",
    "@iedora/product-menu": "workspace:*",
    "lucide-react": "^1.16.0",
    "next": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tw-animate-css": "^1.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@playwright/test": "^1.60.0",
    "postgres": "^3.4.9",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:"
  }
}

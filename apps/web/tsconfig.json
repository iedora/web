{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2023"],
    "allowJs": true,
    "incremental": true,
    "noEmit": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    // No `paths` mapping needed. Apps/web routes import via package
    // names (`@iedora/product-menu/...`, etc.);
    // every workspace package uses relative imports internally so
    // no per-product path entries pollute this file as products
    // accumulate.
  },
  // Project references — workspace packages that emit their own `.d.ts`
  // get listed here. `tsc --build` orchestrates: builds each
  // referenced project first (incremental, cached), then typechecks
  // this one. The referenced projects' internal path mappings stay
  // hidden behind their .d.ts outputs.
  //
  // Adding a new product:
  //   1. Make the product's tsconfig composite (see products/menu/tsconfig.json).
  //   2. Append `{ "path": "../../products/<name>" }` here.
  //   3. Add the package to dependencies + transpilePackages as usual.
  "references": [
    { "path": "../../products/menu" }
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "tests/**"]
}

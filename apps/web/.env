# Single source of truth for LOCAL DEV env (runtime).
# Consumed by next dev (`bun run dev`). The backend (Postgres, MinIO,
# NATS, the Go services) lives in services/docker-compose.yml —
# `bun run dev:up`. Tracked — sem secrets, só valores fake locais.

# --- Go backend (services/docker-compose.yml host ports) ---
AUTH_URL=http://localhost:8080
MENU_URL=http://localhost:8084

# --- Public product URLs (NEXT_PUBLIC_* — inlined at build time) ---
NEXT_PUBLIC_MENU_URL=http://localhost:3000/menu
NEXT_PUBLIC_BRAND_URL=http://localhost:3000/house

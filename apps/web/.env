# Single source of truth for LOCAL DEV env (runtime).
# Consumed by drizzle migrations (`bun run dev:migrate`) and next dev
# (`bun run dev`). Compose ports/buckets vivem hardcoded em
# dev/docker-compose.yml. Tracked — sem secrets, só valores fake locais.

# --- Postgres (one server, two databases — created by config/postgres/init.sql) ---
MENU_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/menu
CORE_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/core

# --- better-auth ---
CORE_SECRET=dev-iedora-auth-secret-do-not-use-in-prod-32chars
CORE_BASE_URL=http://localhost:3000
CORE_TRUSTED_ORIGINS=http://localhost:3000
CORE_COOKIE_DOMAIN=localhost
# CSV de emails auto-promovidos a iedora-admin no signup E reconciliados
# em cada login (cobre o caso de editar a CSV depois do user já existir).
IEDORA_BOOTSTRAP_ADMIN_EMAILS=eduardoferdcarvalho@gmail.com
NEXT_PUBLIC_CORE_URL=http://localhost:3000/core
NEXT_PUBLIC_MENU_URL=http://localhost:3000/menu
NEXT_PUBLIC_BRAND_URL=http://localhost:3000/house

DISABLE_RATE_LIMIT=true

# --- S3 (MinIO local) ---
# Dev usa MinIO local (compose service `minio`, bucket bootstrap em
# `minio-bootstrap`). Console em http://localhost:9001 (minioadmin/minioadmin).
# Pra apontar pra R2 real, sobrescreve estas no apps/web/.env.local.
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=iedora-dev-assets
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/iedora-dev-assets

# --- Secrets ---
# AI keys + R2 overrides vivem em apps/web/.env.local — gitignored +
# Next hot-reloads quando muda. Aqui só fica config não-secret.

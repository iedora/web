{
  "name": "@iedora/ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Iedora AI surface — provider-agnostic factories returning AI SDK LanguageModel instances. Products own their own schemas, prompts, and ports; this package owns nothing but vendor wiring (base URL, env var, model id).",
  "exports": {
    ".": "./src/index.ts",
    "./kimi": "./src/ai-providers/kimi.ts",
    "./deepseek": "./src/ai-providers/deepseek.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "ai": "^6.0.198"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}

{
  "name": "@iedora/core-billing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Iedora billing surface — tenant_subscription + invoice tables (in core schema), Stripe-shape status taxonomy, and the read/write helpers every product consumes for plan + invoice queries. No FK across product DBs (microservices-ready).",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./literals": "./src/literals.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@iedora/core-auth": "workspace:*",
    "@iedora/brand": "workspace:*",
    "@iedora/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}

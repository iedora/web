{
  "name": "@iedora/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Iedora auth surface \u2014 better-auth instance, Drizzle schema, and the role/scope access-control taxonomy shared by every iedora product.",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts",
    "./next": "./src/next.ts",
    "./server": "./src/server/index.ts",
    "./role-presets": "./src/role-presets.ts",
    "./scopes": "./src/scopes.ts",
    "./audit": "./src/audit.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@iedora/billing": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/core-tenancy": "workspace:*",
    "better-auth": "^1.6.11",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.9",
    "server-only": "^0.0.1",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/react": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}

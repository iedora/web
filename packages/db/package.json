{
  "name": "@iedora/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared drizzle-orm + postgres-js setup. Per-product packages define their own schemas and instantiate via createDb(url, schema). PGLite test fixture lives here too \u2014 generic over schema.",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts",
    "./migrate": "./src/migrate.mjs",
    "./scripts/run-migrations": "./scripts/run-migrations.mjs"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@iedora/observability": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.9",
    "server-only": "^0.0.1"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.4.5"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
